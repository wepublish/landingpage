{
  "name": "newsletter-landing-page",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "dotenv -- npm run resolve-config && next dev",
    "resolve-config": "dotenv -- npx tsx scripts/resolve-config.ts",
    "build": "dotenv -- npm run resolve-config && next build",
    "build:cloudflare": "dotenv -- npm run resolve-config && npx @opennextjs/cloudflare build",
    "start": "next start",
    "preview:cloudflare": "wrangler dev",
    "print:pdf": "npx tsx scripts/print-pdf.ts",
    "lint": "eslint"
  },
  "dependencies": {
    "@iframe-resizer/child": "^5.5.9",
    "@next/third-parties": "^16.0.1",
    "@wepublish/wepublish-mailchimp": "^1.1.0",
    "next": "^16.2.6",
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.17.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "baseline-browser-mapping": "^2.9.5",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.0.1",
    "pdf-lib": "^1.17.1",
    "puppeteer": "^25.1.0",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "wrangler": "^4.75.0"
  }
}
